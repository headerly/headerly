{
  "name": "headerly",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.0.3+sha512.10448f2988933787c6699aef683174c741f6472ad91b7e3c8fe3e2bda57be8a0f7caf58949b8bc22e624578b3dc6e57876ba4c631928a1b84cc141e12c79bccd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/headerly/headerly.git"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "pnpm --filter=extension run dev",
    "build": "pnpm --filter=extension run build",
    "analyze": "pnpm --filter=extension run analyze",
    "docs:dev": "pnpm --filter=docs run dev",
    "docs:build": "pnpm --filter=docs run build",
    "docs:preview": "pnpm --filter=docs run preview",
    "zip": "pnpm --filter=extension run zip",
    "test": "pnpm --recursive --sequential run test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "typecheck": "pnpm --recursive --sequential run typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/types": "catalog:",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-better-tailwindcss": "catalog:",
    "lefthook": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vue-tsc": "catalog:"
  }
}
